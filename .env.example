# Offline Kasm: local Docker Chrome-only (not a full desktop). No API keys.
KASM_ENABLED=false
KASM_MODE=offline
KASM_MAX_SESSIONS=1

# After: ./scripts/start_kasm_local.sh
# Watch uses HTTPS + ?resize=remote so the desktop follows your window size.
KASM_CDP_ENDPOINTS=http://127.0.0.1:9333
KASM_VIEW_URLS=https://127.0.0.1:6911/?resize=remote
